---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Çekmeköy TV Servisi | Panel Değişimi | Pasifik Display";
const description = "Çekmeköy televizyon servisi. Panel değişimi, LED değişimi ve TV tamiri.";
const canonical = "/cekmekoy-tv-servisi/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

<section class="mx-auto max-w-5xl px-4 py-12">

<h1 class="text-4xl font-bold text-slate-900">
Çekmeköy TV Servisi
</h1>

<p class="mt-4 text-lg text-slate-600">
Çekmeköy ve çevresinde televizyon panel değişimi,
LED değişimi ve teknik servis hizmetleri verilmektedir.
</p>

</section>

</BaseLayout>