---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getBrandBySlug, getModelsForBrand, getAllBrands } from "../../../lib/data";

export async function getStaticPaths() {
  const brands = getAllBrands();
  return brands.map((b) => ({ params: { brand: b.slug } }));
}

const brandSlug = Astro.params.brand;

if (!brandSlug) {
  return new Response("Not found", { status: 404 });
}

const brand = getBrandBySlug(brandSlug);

if (!brand) {
  return new Response("Not found", { status: 404 });
}

const allModels = getModelsForBrand(brandSlug);
const DEV_LIMIT = 200;
const models = import.meta.env.DEV ? allModels.slice(0, DEV_LIMIT) : allModels;

const canonical = `/markalar/${brandSlug}/`;
const title = `${brand.name} TV Modelleri | Pasifik Display Teknik Servis`;
const description = `${brand.name} televizyon modelleri için panel değişimi, LED değişimi, PSU ve anakart tamiri hizmetleri. Pasifik Display Teknik Servis İstanbul Ümraniye Tepeüstü merkezlidir.`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="border-b border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <div class="max-w-4xl">
        <p class="mb-3 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700">
          Marka Bazlı Servis Sayfası
        </p>

        <h1 class="text-4xl font-bold tracking-tight text-slate-900">
          {brand.name} TV Modelleri
        </h1>

        <p class="mt-4 text-lg leading-8 text-slate-600">
          {brand.name} marka televizyonlar için model bazlı servis sayfalarını inceleyebilir,
          panel değişimi, LED değişimi, LED reflektör değişimi, TV PSU tamiri ve
          TV anakart tamiri hakkında bilgi alabilirsiniz.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/iletisim/"
            class="inline-flex items-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800"
          >
            İletişime Geç
          </a>

          <a
            href="/hizmetler/"
            class="inline-flex items-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50"
          >
            Hizmetler
          </a>
        </div>

        <div class="mt-6">
          <p class="text-sm text-slate-500">
            {import.meta.env.DEV
              ? `Dev mod: İlk ${models.length} model gösteriliyor.`
              : `Toplam ${models.length} model listeleniyor.`}
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    {models.length === 0 ? (
      <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-sm text-slate-700">
          Bu marka için henüz model kaydı bulunamadı.
        </p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 xl:grid-cols-3">
        {models.map((m) => (
          <article class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                  {brand.name}
                </p>
                <h2 class="mt-2 text-xl font-semibold text-slate-900">
                  {m.modelCode}
                </h2>
              </div>

              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                Model
              </span>
            </div>

            <p class="mt-4 text-sm leading-7 text-slate-600">
              Bu model için panel değişimi, LED arızası, PSU ve anakart tamiri gibi
              servis işlemleri hakkında bilgi alabilirsiniz.
            </p>

            <div class="mt-6 flex items-center justify-between">
              <a
                class="inline-flex items-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800"
                href={`/markalar/${brandSlug}/${m.slug}/`}
              >
                Model detayı
              </a>

              <span class="text-sm text-slate-400 group-hover:text-slate-600">
                →
              </span>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>