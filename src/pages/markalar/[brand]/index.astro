---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getBrandBySlug, getModelsForBrand, getAllBrands } from "../../../lib/data";

/** Dynamic route için gerekli */
export async function getStaticPaths() {
  const brands = getAllBrands();
  return brands.map((b) => ({ params: { brand: b.slug } }));
}

const brandSlug = Astro.params.brand;
if (!brandSlug) return new Response("Not found", { status: 404 });

const brand = getBrandBySlug(brandSlug);
if (!brand) return new Response("Not found", { status: 404 });

const allModels = getModelsForBrand(brandSlug);

/**
 * ✅ DEV modda: sadece ilk N model listelensin.
 * Böylece listede görünen her link çalışır (404 sürprizi olmaz).
 * BUILD'de: tüm modeller listelenir.
 */
const DEV_LIMIT = 200;
const models = import.meta.env.DEV ? allModels.slice(0, DEV_LIMIT) : allModels;

const canonical = `/markalar/${brandSlug}/`;
const title = `Pasifik Display | ${brand.name} TV Modelleri`;
const description = `Pasifik Display TV & Panel kataloğu. ${brand.name} markasının TV modelleri listesi.`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-tight text-slate-900">
        {brand.name} TV Modelleri
      </h1>

      <p class="mt-2 text-sm text-slate-600">
        {import.meta.env.DEV ? (
          <>Dev mod: İlk {models.length} model gösteriliyor.</>
        ) : (
          <>Toplam {models.length} model listeleniyor.</>
        )}
      </p>
    </header>

    {models.length === 0 ? (
      <div class="rounded-2xl border border-slate-200 bg-white p-6">
        <p class="text-sm text-slate-700">Bu marka için henüz model kaydı bulunamadı.</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {models.map((m) => (
          <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <h2 class="text-lg font-semibold text-slate-900">{m.modelCode}</h2>

            <!-- vendor/kaynak yok -->

            <div class="mt-4">
              <a
                class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-700"
                href={`/markalar/${brandSlug}/${m.slug}/`}
              >
                Model detayı →
              </a>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
</BaseLayout>