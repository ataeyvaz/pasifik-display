---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/ui/Container.astro";
import Card from "../../../components/ui/Card.astro";

import { getAllBrands } from "../../../lib/data/brands";
import { getAllBrandSlugs, getModelsByBrand } from "../../../lib/data/models";

export async function getStaticPaths() {
  return getAllBrandSlugs().map((slug) => ({
    params: { brand: slug },
  }));
}

const { brand } = Astro.params;
const brandSlug = String(brand);

const brands = getAllBrands();
const b = brands.find((x) => x.slug === brandSlug);

if (!b) {
  throw new Error(`Brand not found: ${brandSlug}`);
}

const models = getModelsByBrand(brandSlug);

const pageTitle = `${b.name} TV Modelleri | Pasifik Display`;
const pageDesc = `${b.name} için TV model listesi. Toplam ${models.length} model.`;
---

<BaseLayout title={pageTitle} description={pageDesc}>
  <Container as="div" class="py-10">
    <h1 class="text-3xl font-bold text-gray-900">{b.name} TV Modelleri</h1>
    <p class="mt-2 text-gray-600">Toplam {models.length} model listeleniyor.</p>

    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      {models.map((m) => (
        <Card class="p-5">
          <div class="font-semibold text-gray-900">{m.modelCode}</div>

          <div class="mt-1 text-xs text-gray-500">
            Kaynak:
            {" "}
            {m.sources.zeroteknik ? "ZeroTeknik" : ""}
            {m.sources.zeroteknik && m.sources.solobu ? " + " : ""}
            {m.sources.solobu ? "Solobu" : ""}
            {!m.sources.zeroteknik && !m.sources.solobu ? "Bilinmiyor" : ""}
          </div>

          <a class="mt-3 inline-flex text-blue-600 hover:underline text-sm"
             href={`/markalar/${b.slug}/${m.slug}/`}>
            Model detayı →
          </a>
        </Card>
      ))}
    </div>
  </Container>
</BaseLayout>
