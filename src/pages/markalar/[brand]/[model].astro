---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  getBrandBySlug,
  getModel,
  getModelsForBrand,
  getPanelsForModel,
  getAllBrands
} from "../../../lib/data";

export async function getStaticPaths() {
  const paths: { params: { brand: string; model: string } }[] = [];
  const brands = getAllBrands();
  const isDev = import.meta.env.DEV;
  const DEV_MODELS_PER_BRAND = 8;

  for (const b of brands) {
    const models = getModelsForBrand(b.slug);
    const slice = isDev ? models.slice(0, DEV_MODELS_PER_BRAND) : models;

    for (const m of slice) {
      paths.push({
        params: { brand: b.slug, model: m.slug },
      });
    }
  }

  return paths;
}

const brandSlug = Astro.params.brand;
const modelSlug = Astro.params.model;

if (!brandSlug || !modelSlug) {
  return new Response("Not found", { status: 404 });
}

const brand = getBrandBySlug(brandSlug);
const model = getModel(brandSlug, modelSlug);

if (!brand || !model) {
  return new Response("Not found", { status: 404 });
}

const panels = getPanelsForModel(brandSlug, modelSlug);

const canonical = `/markalar/${brandSlug}/${modelSlug}/`;
const title = `${brand.name} ${model.modelCode} TV Panel Değişimi | İstanbul Ümraniye Servisi`;
const description =
  `${brand.name} ${model.modelCode} televizyon modeli için panel değişimi, LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri hizmetleri. Pasifik Display Teknik Servis İstanbul Ümraniye Tepeüstü merkezlidir.`;
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <nav aria-label="Breadcrumb" class="text-sm text-slate-500">
      <ol class="flex flex-wrap gap-2">
        <li class="flex items-center gap-2">
          <a class="hover:text-slate-800" href="/">Ana Sayfa</a>
          <span class="opacity-40">/</span>
        </li>
        <li class="flex items-center gap-2">
          <a class="hover:text-slate-800" href="/markalar/">Markalar</a>
          <span class="opacity-40">/</span>
        </li>
        <li class="flex items-center gap-2">
          <a class="hover:text-slate-800" href={`/markalar/${brand.slug}/`}>{brand.name}</a>
          <span class="opacity-40">/</span>
        </li>
        <li class="flex items-center gap-2">
          <a class="hover:text-slate-800" href={canonical}>{model.modelCode}</a>
        </li>
      </ol>
    </nav>

    <header class="mt-4 max-w-4xl">
      <p class="mb-3 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700">
        İstanbul Ümraniye Tepeüstü Teknik Servis
      </p>

      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {brand.name} {model.modelCode} TV Panel Değişimi
      </h1>

      <p class="mt-4 text-base leading-8 text-slate-600">
        {brand.name} {model.modelCode} televizyon modelinde ekran kırılması,
        görüntü gitmesi, panel çatlağı, arka aydınlatma arızası ve kart kaynaklı
        sorunlarda teknik servis desteği verilmektedir. Pasifik Display Teknik Servis,
        İstanbul Ümraniye Tepeüstü merkezli olarak Anadolu Yakası başta olmak üzere
        İstanbul genelinden cihaz kabul etmektedir.
      </p>
    </header>

    <div class="mt-8 grid grid-cols-1 gap-6 lg:grid-cols-3">
      <div class="lg:col-span-2 space-y-6">
        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold text-slate-900">Bu Model İçin Verilen Hizmetler</h2>

          <div class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-2">
            <div class="rounded-2xl border border-slate-200 p-4">
              <h3 class="font-semibold text-slate-900">Panel Değişimi</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                Ekran kırılması, panel çatlağı veya görüntü kaybı sorunlarında
                panel değişimi hizmeti sunulmaktadır.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 p-4">
              <h3 class="font-semibold text-slate-900">LED Değişimi</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                Ses var görüntü yok, karanlık ekran ve arka aydınlatma problemlerinde
                LED değişimi yapılmaktadır.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 p-4">
              <h3 class="font-semibold text-slate-900">LED Reflektör Değişimi</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                Parlak leke, ışık izi ve aydınlatma dengesizliği sorunlarında
                LED reflektör onarımı yapılmaktadır.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 p-4">
              <h3 class="font-semibold text-slate-900">TV PSU Tamiri veya Değişimi</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                Güç kartı arızalarında teknik kontrol sonrası PSU tamiri veya
                değişimi uygulanmaktadır.
              </p>
            </div>

            <div class="rounded-2xl border border-slate-200 p-4 md:col-span-2">
              <h3 class="font-semibold text-slate-900">TV Anakart Tamiri veya Değişimi</h3>
              <p class="mt-2 text-sm leading-7 text-slate-600">
                Açılmama, görüntü vermeme, HDMI sorunları ve anakart kaynaklı
                arızalarda tamir veya değişim hizmeti verilmektedir.
              </p>
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold text-slate-900">Uyumlu Panel Bilgisi</h2>

          {panels.length === 0 ? (
            <div class="mt-4 rounded-2xl border border-dashed border-slate-200 bg-slate-50 p-4">
              <p class="text-sm text-slate-700">
                Bu model için doğrulanmış panel kaydı henüz eklenmemiştir.
              </p>
              <p class="mt-2 text-sm text-slate-600">
                Panel uygunluğu, arıza tipi ve cihaz durumu teknik inceleme sonrası netleştirilebilir.
              </p>
            </div>
          ) : (
            <div class="mt-5 overflow-hidden rounded-2xl border border-slate-200">
              <table class="w-full text-sm">
                <thead class="bg-slate-50 text-left text-slate-600">
                  <tr>
                    <th class="px-4 py-3 font-medium">Panel Kodu</th>
                    <th class="px-4 py-3 font-medium">Güven</th>
                    <th class="px-4 py-3 font-medium">Not</th>
                  </tr>
                </thead>
                <tbody>
                  {panels.map((p) => (
                    <tr class="border-t border-slate-200">
                      <td class="px-4 py-3 font-mono text-slate-900">{p.panelCode}</td>
                      <td class="px-4 py-3">
                        <span class="inline-flex rounded-full bg-slate-100 px-2 py-1 text-xs text-slate-700">
                          {p.confidence ?? "medium"}
                        </span>
                      </td>
                      <td class="px-4 py-3 text-slate-700">{p.note ?? "-"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h2 class="text-2xl font-semibold text-slate-900">Servis Süreci</h2>
          <p class="mt-4 text-sm leading-8 text-slate-600">
            Müşteriler cihazlarını servis merkezimize getirebilir. Yerinde servis,
            yol ve servis ücreti için önceden iletişim kurulması gerekmektedir.
            İşlem öncesinde model, arıza tipi ve parça durumu değerlendirilir.
          </p>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">İletişim</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            WhatsApp, telefon ve konum bilgileri netleştiğinde bu alana eklenecek.
          </p>

          <div class="mt-5 space-y-3">
            <div class="rounded-2xl border border-slate-200 p-4 text-sm text-slate-700">
              WhatsApp: Buraya numara eklenecek
            </div>
            <div class="rounded-2xl border border-slate-200 p-4 text-sm text-slate-700">
              Telefon: Buraya telefon numarası eklenecek
            </div>
            <div class="rounded-2xl border border-slate-200 p-4 text-sm text-slate-700">
              Konum: Buraya Google Maps linki eklenecek
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Servis Bölgeleri</h3>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Ümraniye, Kadıköy, Üsküdar, Çekmeköy, Maltepe, Sancaktepe,
            Samandıra, Sultanbeyli ve yakın çevre bölgelerden servis talepleri
            değerlendirilmektedir.
          </p>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Geri Dön</h3>
          <div class="mt-4 flex flex-col gap-3">
            <a
              class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              href={`/markalar/${brand.slug}/`}
            >
              ← {brand.name} modelleri
            </a>

            <a
              class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              href="/hizmetler/"
            >
              Hizmetler
            </a>

            <a
              class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-50"
              href="/iletisim/"
            >
              İletişim
            </a>
          </div>
        </section>
      </aside>
    </div>
  </section>
</BaseLayout>