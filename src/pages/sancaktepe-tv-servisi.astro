---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Sancaktepe TV Servisi | Panel Değişimi";
const description = "Sancaktepe televizyon teknik servis hizmeti.";
const canonical = "/sancaktepe-tv-servisi/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

<section class="mx-auto max-w-5xl px-4 py-12">

<h1 class="text-4xl font-bold text-slate-900">
Sancaktepe TV Servisi
</h1>

<p class="mt-4 text-lg text-slate-600">
Sancaktepe bölgesinde televizyon panel değişimi,
LED değişimi ve televizyon tamiri hizmetleri verilmektedir.
</p>

</section>

</BaseLayout>