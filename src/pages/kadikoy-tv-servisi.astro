---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Kadıköy TV Servisi | Panel ve LED Değişimi | Pasifik Display Teknik Servis";
const description =
  "Kadıköy bölgesine yönelik TV panel değişimi, LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri hizmetleri. Pasifik Display Teknik Servis Ümraniye Tepeüstü merkezlidir.";
const canonical = "/kadikoy-tv-servisi/";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <header class="max-w-3xl">
      <p class="mb-3 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700">
        Kadıköy ve Çevresi
      </p>

      <h1 class="text-4xl font-bold tracking-tight text-slate-900">
        Kadıköy TV Servisi
      </h1>

      <p class="mt-4 text-lg leading-8 text-slate-600">
        Kadıköy bölgesinden gelen televizyon arızaları için panel değişimi,
        LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri
        hizmetleri verilmektedir. Servis merkezimiz Ümraniye Tepeüstü bölgesindedir.
      </p>
    </header>

    <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Kadıköy İçin Servis Desteği</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Kadıköy, Acıbadem, Kozyatağı, Bostancı, Fikirtepe, Göztepe ve yakın
          çevreden gelen televizyon cihazları servis merkezimizde incelenmektedir.
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Verilen Hizmetler</h2>
        <ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-7 text-slate-600">
          <li>TV panel değişimi</li>
          <li>LED değişimi</li>
          <li>LED reflektör değişimi</li>
          <li>TV PSU tamiri veya değişimi</li>
          <li>TV anakart tamiri veya değişimi</li>
        </ul>
      </div>
    </div>

    <div class="mt-8 rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <h2 class="text-2xl font-semibold text-slate-900">Servis Süreci</h2>
      <p class="mt-4 text-sm leading-8 text-slate-600">
        Müşteriler cihazlarını servis noktasına teslim edebilir. Yerinde servis,
        yol ve servis ücreti için önceden iletişim kurulması gerekmektedir.
        İşlem öncesinde model, arıza tipi ve servis şekli değerlendirilir.
      </p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href="/iletisim/" class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800">
          İletişime Geç
        </a>
        <a href="/markalar/" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-800 hover:bg-white">
          Model Ara
        </a>
      </div>
    </div>
  </section>
</BaseLayout>