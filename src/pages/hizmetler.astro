---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Hizmetler | Pasifik Display Teknik Servis";
const description =
  "Panel değişimi, LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri hizmetleri. Pasifik Display Teknik Servis İstanbul Ümraniye Tepeüstü merkezlidir.";
const canonical = "/hizmetler/";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <header class="max-w-3xl">
      <p class="mb-3 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700">
        Pasifik Display Teknik Servis
      </p>

      <h1 class="text-4xl font-bold tracking-tight text-slate-900">
        Hizmetlerimiz
      </h1>

      <p class="mt-4 text-lg leading-8 text-slate-600">
        İstanbul Ümraniye Tepeüstü merkezli teknik servisimiz; panel değişimi,
        LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri
        hizmetleri vermektedir. Anadolu Yakası başta olmak üzere İstanbul
        genelinden cihaz kabul edilmektedir.
      </p>
    </header>

    <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-2">
      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-slate-900">Panel Değişimi</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Televizyon ekran kırılması, panel çatlağı, görüntü gelmemesi veya
          panel kaynaklı renk bozulmalarında panel değişimi hizmeti verilmektedir.
          Model ve panel uygunluğu kontrol edilerek işlem planlanır.
        </p>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-slate-900">LED Değişimi</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Televizyon arka aydınlatma sistemi arızalarında LED değişimi yapılır.
          Karanlık ekran, ses var görüntü yok, ışık dengesizliği gibi sorunlarda
          teknik inceleme sonrası uygun işlem uygulanır.
        </p>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-slate-900">LED Reflektör Değişimi</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Ekranda parlak leke, dairesel ışık izi veya dengesiz aydınlatma
          problemlerinde LED reflektör değişimi ve iç aydınlatma bakımı yapılmaktadır.
        </p>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-slate-900">TV PSU Tamiri veya Değişimi</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          Güç kartı arızalarında televizyon hiç açılmayabilir veya düzensiz çalışabilir.
          Bu durumlarda TV PSU tamiri veya gerekli durumlarda kart değişimi yapılmaktadır.
        </p>
      </article>

      <article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm lg:col-span-2">
        <h2 class="text-2xl font-semibold text-slate-900">TV Anakart Tamiri veya Değişimi</h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          HDMI giriş sorunları, görüntü işlem hataları, açılmama, logo ekranında kalma
          ve çeşitli anakart kaynaklı arızalarda anakart tamiri veya değişimi hizmeti sunulmaktadır.
        </p>
      </article>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <div class="rounded-3xl bg-white p-6 shadow-sm">
        <h2 class="text-2xl font-semibold text-slate-900">Servis ve Bölge Bilgisi</h2>
        <p class="mt-4 text-sm leading-8 text-slate-600">
          Servis merkezimiz Ümraniye Tepeüstü bölgesindedir. Kadıköy, Üsküdar,
          Çekmeköy, Maltepe, Sancaktepe, Samandıra, Sultanbeyli ve yakın çevrelerden
          servis talepleri değerlendirilmektedir. Müşteriler cihazlarını servis
          noktasına getirebilir. Yerinde servis, yol ve servis ücreti için önceden
          iletişim kurulması gerekmektedir.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href="/iletisim/"
            class="inline-flex items-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800"
          >
            İletişime Geç
          </a>

          <a
            href="/markalar/"
            class="inline-flex items-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50"
          >
            Model Listesini İncele
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>