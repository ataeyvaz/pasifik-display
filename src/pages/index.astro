---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Pasifik Display | Demo" description="Pasifik Display tasarım sistemi demo sayfası.">
  <div class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Pasifik Display UI Demo</h1>
    <p class="mt-3 text-gray-600">
      Bu demo, Trust & Service + teknik disiplin tasarım sistemine göre hazırlanmıştır.
    </p>

    <div class="mt-8 flex gap-3">
      <a
        class="inline-flex items-center justify-center text-sm font-semibold px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-colors"
        href="/demo/model"
      >
        Model Sayfası Demosu 
      </a>
    </div>
  </div>
</BaseLayout>