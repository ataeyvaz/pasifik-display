---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Pasifik Display Teknik Servis | TV Panel Değişimi İstanbul Ümraniye";
const description =
  "Pasifik Display Teknik Servis İstanbul Ümraniye Tepeüstü merkezli TV tamir servisidir. Panel değişimi, LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri hizmetleri verilmektedir. Anadolu Yakası ve İstanbul geneline hizmet sunulmaktadır.";
const canonical = "/";
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <p class="mb-3 inline-flex rounded-full bg-slate-100 px-3 py-1 text-sm font-medium text-slate-700">
          İstanbul Ümraniye Tepeüstü
        </p>

        <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
          Pasifik Display Teknik Servis
        </h1>

        <p class="mt-4 text-lg leading-8 text-slate-600">
          TV panel değişimi, LED değişimi, LED reflektör değişimi, TV PSU tamiri
          ve TV anakart tamiri hizmetleri sunuyoruz. Ümraniye Tepeüstü merkezli
          teknik servisimiz, Anadolu Yakası başta olmak üzere İstanbul genelinden
          cihaz kabul etmektedir.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/hizmetler/"
            class="inline-flex items-center rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800"
          >
            Hizmetleri İncele
          </a>

          <a
            href="/markalar/"
            class="inline-flex items-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50"
          >
            Marka ve Model Listesi
          </a>

          <a
            href="/iletisim/"
            class="inline-flex items-center rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-800 hover:bg-slate-50"
          >
            İletişim
          </a>
        </div>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-xl font-semibold text-slate-900">Verdiğimiz Hizmetler</h2>

        <div class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2">
          <div class="rounded-2xl border border-slate-200 p-4">
            <h3 class="font-semibold text-slate-900">Panel Değişimi</h3>
            <p class="mt-2 text-sm text-slate-600">
              Kırık ekran, panel çatlağı ve görüntü kaybı sorunlarında panel değişimi yapılır.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 p-4">
            <h3 class="font-semibold text-slate-900">LED Değişimi</h3>
            <p class="mt-2 text-sm text-slate-600">
              Arka aydınlatma arızalarında LED değişimi ve aydınlatma onarımı yapılır.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 p-4">
            <h3 class="font-semibold text-slate-900">LED Reflektör Değişimi</h3>
            <p class="mt-2 text-sm text-slate-600">
              Ekranda ışık lekesi ve dengesiz aydınlatma sorunlarında reflektör onarımı yapılır.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 p-4">
            <h3 class="font-semibold text-slate-900">TV PSU Tamiri</h3>
            <p class="mt-2 text-sm text-slate-600">
              Güç kartı arızalarında tamir veya kart değişimi hizmeti verilir.
            </p>
          </div>

          <div class="rounded-2xl border border-slate-200 p-4 sm:col-span-2">
            <h3 class="font-semibold text-slate-900">TV Anakart Tamiri</h3>
            <p class="mt-2 text-sm text-slate-600">
              Açılmama, görüntü vermeme, port arızaları ve anakart kaynaklı sorunlarda teknik destek sağlanır.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50">
    <div class="mx-auto max-w-6xl px-4 py-12">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900">Servis Bölgeleri</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Ümraniye, Kadıköy, Üsküdar, Çekmeköy, Maltepe, Sancaktepe,
            Samandıra, Sultanbeyli, Ataşehir, Kartal, Pendik ve çevre bölgeler
            başta olmak üzere İstanbul genelinden cihaz kabul edilmektedir.
          </p>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900">Servis Notu</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Müşteriler cihazlarını servis noktasına getirebilir. Yerinde servis,
            yol ve servis ücreti için önceden iletişim kurulması gerekmektedir.
          </p>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-slate-900">Model Bazlı Arama</h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            Marka ve model sayfalarımız üzerinden televizyon modelinizi
            bularak panel değişimi, LED arızası, PSU ve anakart tamiri için
            bilgi alabilirsiniz.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
      <a href="/istanbul-tv-servisi/" class="rounded-2xl border border-slate-200 p-5 hover:bg-slate-50">
        <h2 class="font-semibold text-slate-900">İstanbul TV Servisi</h2>
        <p class="mt-2 text-sm text-slate-600">
          İstanbul genelinde TV tamiri ve panel değişimi hizmeti.
        </p>
      </a>

      <a href="/umraniye-tv-servisi/" class="rounded-2xl border border-slate-200 p-5 hover:bg-slate-50">
        <h2 class="font-semibold text-slate-900">Ümraniye TV Servisi</h2>
        <p class="mt-2 text-sm text-slate-600">
          Ümraniye ve çevresine özel teknik servis içerikleri.
        </p>
      </a>

      <a href="/kadikoy-tv-servisi/" class="rounded-2xl border border-slate-200 p-5 hover:bg-slate-50">
        <h2 class="font-semibold text-slate-900">Kadıköy TV Servisi</h2>
        <p class="mt-2 text-sm text-slate-600">
          Kadıköy bölgesine yönelik TV panel ve LED tamiri hizmeti.
        </p>
      </a>

      <a href="/markalar/" class="rounded-2xl border border-slate-200 p-5 hover:bg-slate-50">
        <h2 class="font-semibold text-slate-900">Marka ve Modeller</h2>
        <p class="mt-2 text-sm text-slate-600">
          TV markaları ve model bazlı teknik destek sayfaları.
        </p>
      </a>
    </div>
  </section>
</BaseLayout>