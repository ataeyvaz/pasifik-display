---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Üsküdar TV Servisi | Panel ve LED Değişimi | Pasifik Display Teknik Servis";
const description = "Üsküdar ve çevresinde TV panel değişimi, LED değişimi ve televizyon tamiri hizmetleri.";
const canonical = "/uskudar-tv-servisi/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

<section class="mx-auto max-w-5xl px-4 py-12">

<h1 class="text-4xl font-bold text-slate-900">
Üsküdar TV Servisi
</h1>

<p class="mt-4 text-lg text-slate-600">
Pasifik Display Teknik Servis olarak Üsküdar ve çevresinde
TV panel değişimi, LED değişimi ve televizyon tamiri
hizmetleri sunmaktayız.
</p>

<p class="mt-4 text-slate-600">
Servis merkezimiz Ümraniye Tepeüstü bölgesindedir.
Üsküdar, Altunizade, Çengelköy, Acıbadem ve çevresinden
cihaz kabul edilmektedir.
</p>

</section>

</BaseLayout>