---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Sultanbeyli TV Servisi | Panel Değişimi";
const description = "Sultanbeyli televizyon tamiri ve panel değişimi.";
const canonical = "/sultanbeyli-tv-servisi/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

<section class="mx-auto max-w-5xl px-4 py-12">

<h1 class="text-4xl font-bold text-slate-900">
Sultanbeyli TV Servisi
</h1>

<p class="mt-4 text-lg text-slate-600">
Sultanbeyli ve çevresinde televizyon panel değişimi,
LED değişimi ve televizyon tamiri hizmetleri sunulmaktadır.
</p>

</section>

</BaseLayout>