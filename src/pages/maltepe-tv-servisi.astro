---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Maltepe TV Servisi | Panel Değişimi | Pasifik Display";
const description = "Maltepe TV teknik servis hizmeti.";
const canonical = "/maltepe-tv-servisi/";
---

<BaseLayout title={title} description={description} canonical={canonical}>

<section class="mx-auto max-w-5xl px-4 py-12">

<h1 class="text-4xl font-bold text-slate-900">
Maltepe TV Servisi
</h1>

<p class="mt-4 text-lg text-slate-600">
Maltepe ve çevresinde televizyon panel değişimi ve
televizyon tamiri hizmetleri sunulmaktadır.
</p>

</section>

</BaseLayout>