---
import Header from "../components/site/Header.astro";
import Footer from "../components/site/Footer.astro";
import MetaTags from "../components/seo/MetaTags.astro";

type Props = {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
};

const {
  title,
  description = "TV ve monitör panel kodları, uyumlu modeller ve teknik referans bilgileri.",
  canonical,
  noindex = false,
} = Astro.props;
---
<!doctype html>
<html lang="tr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <MetaTags title={title} description={description} canonical={canonical} noindex={noindex} />
  </head>
  <body>
    <Header />
    <main class="min-h-[60vh]">
      <slot />
    </main>
    <Footer />
  </body>
</html>