---
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-12">
    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 xl:grid-cols-4">
      <div>
        <h2 class="text-lg font-semibold text-slate-900">
          Pasifik Display Teknik Servis
        </h2>
        <p class="mt-4 text-sm leading-7 text-slate-600">
          İstanbul Ümraniye Tepeüstü merkezli teknik servisimiz; TV panel değişimi,
          LED değişimi, LED reflektör değişimi, TV PSU tamiri ve TV anakart tamiri
          hizmetleri sunmaktadır.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">
          Hızlı Linkler
        </h3>
        <ul class="mt-4 space-y-3 text-sm text-slate-600">
          <li>
            <a href="/" class="hover:text-slate-900">Ana Sayfa</a>
          </li>
          <li>
            <a href="/hizmetler/" class="hover:text-slate-900">Hizmetler</a>
          </li>
          <li>
            <a href="/markalar/" class="hover:text-slate-900">Markalar</a>
          </li>
          <li>
            <a href="/iletisim/" class="hover:text-slate-900">İletişim</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">
          Hizmetler
        </h3>
        <ul class="mt-4 space-y-3 text-sm text-slate-600">
          <li>Panel değişimi</li>
          <li>LED değişimi</li>
          <li>LED reflektör değişimi</li>
          <li>TV PSU tamiri veya değişimi</li>
          <li>TV anakart tamiri veya değişimi</li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wide text-slate-900">
          Servis Bölgeleri
        </h3>
        <ul class="mt-4 space-y-3 text-sm text-slate-600">
          <li><a href="/istanbul-tv-servisi/" class="hover:text-slate-900">İstanbul TV Servisi</a></li>
          <li><a href="/umraniye-tv-servisi/" class="hover:text-slate-900">Ümraniye TV Servisi</a></li>
          <li><a href="/kadikoy-tv-servisi/" class="hover:text-slate-900">Kadıköy TV Servisi</a></li>
          <li><a href="/uskudar-tv-servisi/" class="hover:text-slate-900">Üsküdar TV Servisi</a></li>
          <li><a href="/cekmekoy-tv-servisi/" class="hover:text-slate-900">Çekmeköy TV Servisi</a></li>
          <li><a href="/maltepe-tv-servisi/" class="hover:text-slate-900">Maltepe TV Servisi</a></li>
          <li><a href="/sancaktepe-tv-servisi/" class="hover:text-slate-900">Sancaktepe TV Servisi</a></li>
          <li><a href="/sultanbeyli-tv-servisi/" class="hover:text-slate-900">Sultanbeyli TV Servisi</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-slate-200 pt-6 text-sm text-slate-500">
      <p>
        © {year} Pasifik Display Teknik Servis. Tüm hakları saklıdır.
      </p>
    </div>
  </div>
</footer>