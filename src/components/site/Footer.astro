---
import Container from "../ui/Container.astro";
---
<footer class="bg-gray-900 text-gray-400 text-sm mt-16">
  <Container as="div" class="py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div>
        <div class="font-bold text-white">Pasifik Display</div>
        <p class="mt-2 text-gray-400">TV ve monitör panel kodları, uyumlu modeller ve teknik referans bilgileri.</p>
      </div>

      <div>
        <div class="font-semibold text-white">Hızlı Erişim</div>
        <ul class="mt-3 space-y-2">
          <li><a class="hover:text-white" href="/markalar">Markalar</a></li>
          <li><a class="hover:text-white" href="/demo/model">Model Demo</a></li>
          <li><a class="hover:text-white" href="/iletisim">İletişim</a></li>
        </ul>
      </div>

      <div>
        <div class="font-semibold text-white">İletişim</div>
        <ul class="mt-3 space-y-2">
          <li> 0xxx xxx xx xx</li>
          <li> info@pasifikdisplay.com</li>
          <li> WhatsApp ile yazın</li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-gray-800 text-xs text-gray-500">
       {new Date().getFullYear()} Pasifik Display  Tüm haklar saklıdır.
    </div>
  </Container>
</footer>