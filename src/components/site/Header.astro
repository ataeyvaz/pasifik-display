---
import SearchBar from './SearchBar.astro';

const phone = "905444868748";
const whatsappHref = `https://wa.me/${phone}?text=Merhaba%2C%20TV%20servis%20hakk%C4%B1nda%20bilgi%20almak%20istiyorum.`;
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="flex items-center gap-3 flex-shrink-0">
      <span class="text-2xl font-bold tracking-tight text-slate-900">
        Pasifik Display
      </span>
      <span class="hidden text-sm text-slate-500 sm:inline">
        Teknik Servis
      </span>
    </a>

    <nav class="hidden items-center gap-8 md:flex flex-shrink-0">
      <a href="/markalar/" class="text-sm font-medium text-slate-700 hover:text-slate-900">
        Markalar
      </a>
      <a href="/hizmetler/" class="text-sm font-medium text-slate-700 hover:text-slate-900">
        Hizmetler
      </a>
      <a href="/istanbul-tv-servisi/" class="text-sm font-medium text-slate-700 hover:text-slate-900">
        Servis Bölgeleri
      </a>
      <a href="/iletisim/" class="text-sm font-medium text-slate-700 hover:text-slate-900">
        İletişim
      </a>
    </nav>

    <!-- Arama Kutusu -->
    <div class="flex-1 hidden md:block">
      <SearchBar variant="light" />
    </div>

    <div class="flex items-center gap-3 flex-shrink-0">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-xl bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700"
      >
        WhatsApp
      </a>
    </div>
  </div>
</header>

<!-- Sabit WhatsApp butonu (sağ alt köşe) -->
<a
  href={whatsappHref}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 flex items-center gap-2 rounded-full bg-emerald-500 px-5 py-3 text-sm font-semibold text-white shadow-lg hover:bg-emerald-600 transition-colors"
  aria-label="WhatsApp ile iletişime geç"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
    <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.554 4.118 1.524 5.855L.057 23.428a.75.75 0 0 0 .916.916l5.573-1.467A11.944 11.944 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75a9.712 9.712 0 0 1-4.953-1.354l-.355-.212-3.678.968.984-3.595-.232-.37A9.712 9.712 0 0 1 2.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"/>
  </svg>
  WhatsApp ile Yaz
</a>